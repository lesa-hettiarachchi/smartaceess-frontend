# Production env vars — Next.js auto-loads this when running `next build`
# (Vercel runs `next build` on every deploy).
#
# This file IS committed to git (see .gitignore exception for .env.production).
# Local dev still uses .env.local which keeps NEXT_PUBLIC_API_URL=http://localhost:8000.

NEXT_PUBLIC_API_URL=https://smartaccess-backend-production.up.railway.app
